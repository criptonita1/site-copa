# ============================================================
# Onde Ver a Copa — variáveis de ambiente
# Copie este arquivo pra .env.local e preencha com valores reais
# ============================================================

# ─── URL canônica do site (usada em OG, sitemap, share, ICS, UTMs) ───
# Em dev local pode deixar http://localhost:3000
# Em prod: https://ondeveracopa.com.br (ou o domínio que você for usar)
NEXT_PUBLIC_SITE_URL=https://ondeveracopa.com.br

# ─── Resend — captura de lead pro lembrete por email ───
# 1. Crie conta em https://resend.com
# 2. Adicione e VERIFIQUE seu domínio em https://resend.com/domains
#    (precisa adicionar 3 registros DNS — SPF, DKIM, MX)
# 3. Crie uma Audience em https://resend.com/audiences (anote o ID)
# 4. Gere API key em https://resend.com/api-keys (escopo: full access)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Email FROM (precisa estar no domínio verificado no Resend)
RESEND_FROM="Onde Ver a Copa <copa@seu-dominio.com.br>"
